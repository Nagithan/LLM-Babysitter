{
	"compilerOptions": {
		"module": "ESNext",
		"target": "ES2022",
		"lib": [
			"ES2022",
			"DOM"
		],
		"sourceMap": true,
		"rootDir": ".",
		"strict": true,
		"skipLibCheck": true,
		"moduleResolution": "Bundler",
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"types": ["vitest/globals"]
	},
	"include": [
		"src/**/*.ts",
		"vitest.config.ts",
		".vscode-test.mjs"
	],
	"exclude": [
		"node_modules",
		"out",
		"dist",
		"coverage"
	]
}