{
  "name": "backseat-pilot",
  "displayName": "Backseat Pilot",
  "description": "Prompt generation with code context for online LLM requests.",
  "publisher": "Nagithan",
  "version": "0.1.0",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nagithan/Backseat-Pilot.git"
  },
  "bugs": {
    "url": "https://github.com/Nagithan/Backseat-Pilot/issues"
  },
  "homepage": "https://github.com/Nagithan/Backseat-Pilot#readme",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "backseat-pilot",
          "title": "Backseat Pilot",
          "icon": "$(rocket)"
        }
      ]
    },
    "views": {
      "backseat-pilot": [
        {
          "type": "webview",
          "id": "backseat-pilot-view",
          "name": "Prompt Generator",
          "icon": "$(rocket)"
        }
      ]
    },
    "commands": [
      {
        "command": "backseat-pilot.refresh",
        "title": "Refresh Explorer",
        "icon": "$(refresh)"
      },
      {
        "command": "backseat-pilot.expandAll",
        "title": "Expand All Files",
        "icon": "$(expand-all)"
      },
      {
        "command": "backseat-pilot.collapseAll",
        "title": "Collapse All Files",
        "icon": "$(collapse-all)"
      },
      {
        "command": "backseat-pilot.blacklist",
        "title": "Never include in Backseat Pilot",
        "icon": "$(circle-slash)"
      }
    ],
    "configuration": {
      "title": "Backseat Pilot",
      "properties": {
        "backseat-pilot.excludePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/node_modules/**",
            "**/.git/**",
            "**/dist/**",
            "**/out/**",
            "**/*.log"
          ],
          "description": "Folders and files to exclude from the context selection."
        }
      }
    },
    "menus": {
      "explorer/context": [
        {
          "command": "backseat-pilot.blacklist",
          "group": "7_modification",
          "when": "resourceScheme == 'file'"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "test:unit": "npm run compile-tests && node_modules/.bin/mocha out/test/unit/*.test.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/sinon": "^21.0.0",
    "@types/vscode": "^1.100.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "esmock": "^2.7.3",
    "mocha": "^11.7.5",
    "npm-run-all": "^4.1.5",
    "sinon": "^21.0.3",
    "source-map-support": "^0.5.21",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "ignore": "^7.0.5",
    "minimatch": "^10.2.5"
  }
}